// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  nickname      String
  createdAt     DateTime          @default(now())
  subscriptions Subscription[]
  channels      UsersOnChannels[]
}

model Subscription {
  id        String   @id @default(cuid())
  data      Json
  counter   Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userRef], references: [id])
  userRef   String
}

model Device {
  id         String      @id @default(cuid())
  name       String
  createdAt  DateTime    @default(now())
  channel    Channel     @relation(fields: [channelRef], references: [id])
  channelRef String
  telemetry  Telemetry[]

  @@unique([channelRef, name])
}

model Telemetry {
  id        String   @id @default(cuid())
  moisture  Float    @db.Real
  battery   Float    @db.Real
  createdAt DateTime @default(now())
  device    Device   @relation(fields: [deviceRef], references: [id])
  deviceRef String

  @@index([deviceRef, createdAt])
}

model Notification {
  id         String   @id @default(cuid())
  title      String
  body       String
  author     String
  createdAt  DateTime @default(now())
  channel    Channel  @relation(fields: [channelRef], references: [id])
  channelRef String

  @@index([channelRef, createdAt])
}

model Channel {
  id            String            @id @default(cuid())
  name          String            @unique
  createdAt     DateTime          @default(now())
  users         UsersOnChannels[]
  devices       Device[]
  notifications Notification[]
}

model UsersOnChannels {
  user       User    @relation(fields: [userRef], references: [id])
  channel    Channel @relation(fields: [channelRef], references: [id])
  userRef    String
  channelRef String

  @@id([userRef, channelRef])
}
