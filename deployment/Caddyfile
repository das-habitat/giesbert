(common) {
    encode gzip
    header {
      Strict-Transport-Security "max-age=31536000;"
      X-XSS-Protection "1; mode=block"
      X-Frame-Options "DENY"
      X-Robots-Tag "none"
      -Server
    }
}

{$SITE_ADDRESS} {
	import common

	handle /api/* {
		reverse_proxy server:3000
	}

	handle {
		root * /srv
		file_server
		try_files {path} /index.html
	}
}

# Catch all: Matches any other domain
:443 {
	import common
	abort
}
